---
import Layout from "../../layouts/Layout.astro";
import { projects } from "../../data/projects";
---

<Layout title="Projects">
  <section class="mx-auto max-w-6xl px-6 py-28">
    <p class="mb-3 text-sm uppercase tracking-[0.3em] text-zinc-500">
      Projects
    </p>

    <h1 class="mb-12 text-5xl font-bold">
      Selected Work
    </h1>

    <div class="grid gap-8 md:grid-cols-2">
      {
        projects.map((project) => (
          <a
            href={`/projects/${project.slug}`}
            class="group block rounded-3xl border border-white/10 bg-white/5 p-8 backdrop-blur-sm transition-all duration-300 hover:-translate-y-2 hover:border-white/20 hover:bg-white/[0.08]"
          >
            <div class="flex items-center justify-between">
              <h2 class="text-2xl font-semibold">
                {project.title}
              </h2>

              <span
                class="text-zinc-500 transition group-hover:translate-x-1 group-hover:text-white"
              >
                →
              </span>
            </div>

            <p class="mt-4 text-zinc-400">
              {project.description}
            </p>

            <div class="mt-6 flex flex-wrap gap-2">
              {
                project.stack.slice(0, 3).map((tech) => (
                  <span
                    class="rounded-full border border-white/10 px-3 py-1 text-xs text-zinc-400"
                  >
                    {tech}
                  </span>
                ))
              }
            </div>

            <p
              class="mt-8 text-sm text-zinc-500 transition group-hover:text-zinc-300"
            >
              View Case Study →
            </p>
          </a>
        ))
      }
    </div>
  </section>
</Layout>