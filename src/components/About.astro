---
const highlights = [
  "React",
  "TypeScript",
  "Next.js",
  "Astro",
  "Performance",
  "Accessibility",
  "Design Systems",
  "Product Thinking"
];
---

<section
  id="about"
  class="mx-auto max-w-6xl px-6 py-28"
>
  <div class="grid gap-12 lg:grid-cols-2">
    <div>
      <p class="mb-3 text-sm uppercase tracking-[0.3em] text-zinc-500">
        About
      </p>

      <h2 class="text-4xl font-bold md:text-5xl">
        Building products,
        not just interfaces.
      </h2>

      <p class="mt-6 text-lg leading-relaxed text-zinc-400">
        Frontend engineer focused on creating scalable,
        performant applications with strong attention
        to user experience, maintainability, and business impact.
      </p>

      <p class="mt-4 text-lg leading-relaxed text-zinc-400">
        I enjoy turning complex requirements into intuitive,
        production-ready experiences using modern frontend
        technologies and thoughtful product decisions.
      </p>
    </div>

    <div
      class="grid grid-cols-2 gap-4"
    >
      {
        highlights.map((item) => (
          <div
            class="rounded-2xl border border-white/10 bg-white/5 p-6 backdrop-blur-sm transition hover:-translate-y-1 hover:border-white/20"
          >
            <p class="font-medium">
              {item}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>