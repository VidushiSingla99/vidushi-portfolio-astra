---
const experiences = [
  {
    role: "Software Developer",
    company: "MangoApps",
    duration: "2022 - Present",
    achievements: [
      "Refactored company pages using React.js, and IndexedDB caching, reducing load time by 25% and bug reports by 15%",
      "Built prompt-driven workflows and service layers integrating AI APIs for automated content and image generation, accelerating page creation and improving user productivity",
      "Led technical planning and execution of a React v0.14 to React v17 migration across 70+ instances"
    ]
  },
  {
    role: "Software Developer Intern",
    company: "GFACTORS",
    duration: "2021 - 2022",
    achievements: [
      "Worked on full-stack development using JavaScript, Bootstrap, Python, Jupyter Libraries, and MongoDB",
    "Learnt Debugging and Optimization"
    ]
  }
];
---

<section
  id="experience"
  class="mx-auto max-w-6xl px-6 py-28"
>
  <div class="mb-16">
    <p class="mb-3 text-sm uppercase tracking-[0.3em] text-zinc-500">
      Experience
    </p>

    <h2 class="text-4xl font-bold md:text-5xl">
      Professional Journey
    </h2>
  </div>

  <div class="relative">
    <div
      class="absolute left-4 top-0 h-full w-px bg-white/10"
    />

    {
      experiences.map((exp) => (
        <div
          class="relative mb-16 pl-16"
        >
          <div
            class="absolute left-0 top-2 h-8 w-8 rounded-full border border-white/20 bg-zinc-900"
          />

          <div
            class="rounded-3xl border border-white/10 bg-white/5 p-8 backdrop-blur-sm"
          >
            <div
              class="flex flex-col gap-2 md:flex-row md:items-center md:justify-between"
            >
              <div>
                <h3 class="text-2xl font-semibold">
                  {exp.role}
                </h3>

                <p class="text-zinc-400">
                  {exp.company}
                </p>
              </div>

              <p class="text-sm text-zinc-500">
                {exp.duration}
              </p>
            </div>

            <ul class="mt-6 space-y-3">
              {
                exp.achievements.map((item) => (
                  <li class="text-zinc-400">
                    • {item}
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      ))
    }
  </div>
</section>