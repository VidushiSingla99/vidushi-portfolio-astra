---
const projects = [
{
title: "Virtual Analytics Workflow",
description:
"AI-powered data analysis platform that transforms CSV uploads into actionable insights, visualizations, and reports.",
stack: ["React", "TypeScript", "OpenAI", "Chart.js"]
},
{
title: "Workflow Builder",
description:
"Visual drag-and-drop workflow builder for creating and managing automation pipelines with reusable nodes and dynamic execution flows.",
stack: ["React", "TypeScript", "Zustand"]
},
{
title: "Personal Portfolio",
description:
"Modern portfolio built with Astro and Tailwind CSS, featuring dynamic project pages, case studies, and performance-focused architecture.",
stack: ["Astro", "TypeScript", "Tailwind CSS"]
}
];

---

<section
  id="projects"
  class="mx-auto max-w-6xl px-6 py-28"
>
  <div class="mb-16">
    <p class="mb-3 text-sm uppercase tracking-[0.3em] text-zinc-500">
      Projects
    </p>

    <h2 class="text-4xl font-bold md:text-5xl">
      Selected Work
    </h2>
  </div>

  <div class="grid gap-8 md:grid-cols-2 xl:grid-cols-3">
    {
      projects.map((project) => (
        <a
          href={`/projects/${project.title.toLowerCase().replace(/\s/g, "-")}`}
          class="group rounded-3xl border border-white/10 bg-white/5 p-8 transition hover:-translate-y-2 hover:border-white/20 block"
        >
          <h3 class="text-2xl font-semibold">
            {project.title}
          </h3>

          <p class="mt-4 text-zinc-400">
            {project.description}
          </p>

          <div class="mt-6 flex flex-wrap gap-2">
            {
              project.stack.map((tech) => (
                <span class="rounded-full border border-white/10 px-3 py-1 text-xs text-zinc-400">
                  {tech}
                </span>
              ))
            }
          </div>
        </a>
      ))
    }
  </div>

  {/* CTA BUTTON - INSIDE SECTION */}
  <div class="mt-12 text-center">
    <a
      href="/projects"
      class="rounded-full border border-white/10 px-6 py-3 transition hover:bg-white hover:text-black"
    >
      View All Projects
    </a>
  </div>
</section>